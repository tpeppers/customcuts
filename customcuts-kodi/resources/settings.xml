<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<settings version="1">
    <section id="customcuts">
        <category id="connection" label="Connection">
            <group id="1" label="Host">
                <setting id="host_url" type="string" label="Host URL" help="e.g. http://192.168.1.42:8787">
                    <level>0</level>
                    <default></default>
                    <control type="edit" format="string">
                        <heading>Host URL</heading>
                    </control>
                </setting>
                <setting id="auth_token" type="string" label="Auth token" help="32-char hex token from the CustomCuts Cast panel">
                    <level>0</level>
                    <default></default>
                    <control type="edit" format="string">
                        <heading>Auth token</heading>
                    </control>
                </setting>
            </group>
            <group id="2" label="Discovery">
                <setting id="auto_discover" type="boolean" label="Run LAN discovery on launch if host is unreachable">
                    <level>0</level>
                    <default>true</default>
                    <control type="toggle"/>
                </setting>
                <setting id="discovery_timeout_ms" type="number" label="Discovery timeout (ms)">
                    <level>0</level>
                    <default>3000</default>
                    <constraints>
                        <minimum>500</minimum>
                        <maximum>10000</maximum>
                        <step>500</step>
                    </constraints>
                    <control type="slider" format="integer">
                        <formatlabel>{0:d} ms</formatlabel>
                    </control>
                </setting>
            </group>
        </category>
    </section>
</settings>
