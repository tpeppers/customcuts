# Python
__pycache__/
*.pyc

# Logs
*.log

# Native host shared secret (auto-generated per install)
native_host/customcuts_host.token

# Chrome native-messaging host manifest (generated by install_stream_host.py,
# contains machine-specific absolute paths and the user's extension ID)
native_host/stream_host_manifest.json
native_host/stream_host_manifest.firefox.json

# Kodi addon build artifact (regenerated from customcuts-kodi/ on demand)
customcuts-kodi.zip

# Roku channel build artifact (regenerated from customcuts-roku/ on demand)
customcuts-roku.zip

# Browser extension build artifacts (regenerated from build_extension.py)
customcuts-chrome.zip
customcuts-firefox.zip

# Native host generated caches (thumbnails for featured grid, transmuxed MP4s)
native_host/thumbs/
native_host/transmux_cache/

# Local test environment scaffolding (BrightScript desktop sim, etc.)
test_env/

# Generated data-source reference audit (not for publication)
DATASOURCE_REFS.txt

# Claude Code local settings
.claude/settings.local.json
